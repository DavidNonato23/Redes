<TelaCadastroCliente>:
    canvas.before:
        Color:
            rgba: 0.2, 0.4, 0.7, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: 30
        spacing: 15

        Label:
            text: "Cadastro de Cliente"
            font_size: 28
            size_hint_y: None
            height: 50
            color: 1,1,1,1

        Label:
            text: "Nome do Cliente"
            size_hint_y: None
            height: 25
            color: 1,1,1,1

        TextInput:
            id: nome_input
            multiline: False
            size_hint_y: None
            height: 35

        Label:
            text: "Usuário PPPoE"
            size_hint_y: None
            height: 25
            color: 1,1,1,1

        TextInput:
            id: usuario_input
            multiline: False
            size_hint_y: None
            height: 35

        Label:
            text: "Senha PPPoE"
            size_hint_y: None
            height: 25
            color: 1,1,1,1

        TextInput:
            id: senha_input
            multiline: False
            password: True
            size_hint_y: None
            height: 35

        Label:
            text: "Plano (ex: 5M/5M)"
            size_hint_y: None
            height: 25
            color: 1,1,1,1

        TextInput:
            id: plano_input
            multiline: False
            size_hint_y: None
            height: 35

        GridLayout:
            cols: 2
            size_hint_y: None
            height: 50
            spacing: 20
            padding: [0,10]

            Button:
                text: "Salvar Cliente"
                on_press: root.salvar_cliente()

            Button:
                text: "Voltar"
                on_press: app.root.current = 'principal'
